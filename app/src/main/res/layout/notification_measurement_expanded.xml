<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/notification_background"
    android:orientation="vertical"
    android:padding="12dp"
    tools:ignore="Overdraw">

    <TextView
        android:id="@+id/notification_session_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope_semibold"
        android:text="@string/notification_live_measurement"
        android:textColor="@color/notification_text_secondary"
        android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="6dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notification_db_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:includeFontPadding="false"
                android:text="@string/notification_db_placeholder"
                android:textColor="@color/notification_text_primary"
                android:textSize="48sp" />

            <TextView
                android:id="@+id/notification_peak_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/notification_peak_duration_placeholder"
                android:textColor="@color/notification_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="92dp"
            android:layout_height="wrap_content"
            android:background="@color/notification_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/notification_noise_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/notification_dot_green"
                android:text="" />

            <TextView
                android:id="@+id/notification_noise_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:paddingTop="6dp"
                android:text="@string/notification_noise_safe"
                android:textColor="@color/notification_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
