---
ignore-paths:
  - .deepsec/
  - .gradle/
  - .idea/
  - .kotlin/
  - .sonar/
  - app/build/
  - app/src/main/res/values
  - app/src/androidTest/
  - app/src/test/
  - build/
  - node_modules/
  - reports/
ignore-rules:
  # Mobsfscan lukee lähdemanifestia eikä näe Gradlen targetSdk=36-arvoa.
  - android_task_hijacking2
