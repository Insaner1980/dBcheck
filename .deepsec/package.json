{
  "private": true,
  "type": "module",
  "scripts": {
    "deepsec": "deepsec",
    "deepsec:scan": "deepsec scan --project-id dbcheck",
    "deepsec:scan:custom": "deepsec scan --project-id dbcheck --matchers android-exported-component,fileprovider-broad-path,android-uri-share-without-clipdata,foreground-audio-service-start,audio-record-capture-surface,health-connect-sensitive-flow,backup-restore-database-file,sensitive-android-log",
    "deepsec:process": "deepsec process --project-id dbcheck --agent codex",
    "deepsec:recover": "node ./scripts/recover-processing-locks.mjs --project-id dbcheck",
    "deepsec:revalidate": "deepsec revalidate --project-id dbcheck --agent codex --min-severity HIGH",
    "deepsec:export": "deepsec export --project-id dbcheck --format md-dir --out ./findings",
    "deepsec:report": "pnpm run deepsec:scan && pnpm run deepsec:recover -- --fail-on-active && pnpm run deepsec:process && pnpm run deepsec:export",
    "deepsec:report:custom": "pnpm run deepsec:scan:custom && pnpm run deepsec:recover -- --fail-on-active && pnpm run deepsec:process && pnpm run deepsec:export",
    "test:recover-locks": "node --test ./scripts/recover-processing-locks.test.mjs"
  },
  "dependencies": {
    "deepsec": "2.1.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.9.3",
    "zod": "4.4.3"
  }
}
